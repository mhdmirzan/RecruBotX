# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (recommended) or self-hosted MongoDB URI
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/recrubotx?retryWrites=true&w=majority

# ─── AI / LLM Keys ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Email (Brevo / Sendinblue) ────────────────────────────────────────────────
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_api_key_here
EMAIL_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=RecruBotX

# ─── Optional: Resend email provider ──────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=RecruBotX <onboarding@resend.dev>

# ─── CORS (set to your Hostinger domain, e.g. http://123.45.67.89 or https://yourdomain.com) ──
ALLOWED_ORIGINS=http://yourdomain.com,https://yourdomain.com

# ─── App settings ─────────────────────────────────────────────────────────────
MONGODB_STRICT_STARTUP=true
